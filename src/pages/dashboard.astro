---
import AppLayout from "@/layouts/app.astro"
import { StatsCards } from "@/components/dashboard/StatsCards"
---

<AppLayout>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-semibold">Dashboard</h1>
      <p class="text-sm text-muted-foreground mt-1">Overview of your Nexus instance</p>
    </div>
    <StatsCards client:load />
    <div class="grid gap-4 md:grid-cols-2 mt-4">
      <div class="rounded-lg border p-4">
        <h2 class="font-medium mb-1">Quick Links</h2>
        <ul class="text-sm space-y-1 text-muted-foreground">
          <li><a href="/api-keys" class="hover:text-foreground underline-offset-4 hover:underline">Manage API Keys →</a></li>
          <li><a href="/emails/templates/new" class="hover:text-foreground underline-offset-4 hover:underline">Create Email Template →</a></li>
          <li><a href="/files" class="hover:text-foreground underline-offset-4 hover:underline">Browse Files →</a></li>
          <li><a href="/database" class="hover:text-foreground underline-offset-4 hover:underline">Explore Database →</a></li>
        </ul>
      </div>
      <div class="rounded-lg border p-4">
        <h2 class="font-medium mb-1">API Base URL</h2>
        <p class="text-sm text-muted-foreground">Use these endpoints with your API key:</p>
        <ul class="text-sm mt-2 space-y-1 font-mono">
          <li>POST /api/email/send</li>
          <li>POST /api/files/upload</li>
          <li>GET  /api/files/[id]</li>
        </ul>
      </div>
    </div>
  </div>
</AppLayout>
