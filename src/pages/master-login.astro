---
import Layout from "@/layouts/main.astro"
import {
  MASTER_AUTH_COOKIE,
  getMasterAuthCookieOptions,
  getMasterPasswordHash,
  isMasterCookieValid,
  isMasterPasswordEnabled,
  sanitizeNextPath,
  verifyMasterPassword,
} from "@/lib/master-auth"

if (!isMasterPasswordEnabled()) {
  return Astro.redirect("/dashboard")
}

const nextPath = sanitizeNextPath(Astro.url.searchParams.get("next"))
const existingCookie = Astro.cookies.get(MASTER_AUTH_COOKIE)?.value

if (isMasterCookieValid(existingCookie)) {
  return Astro.redirect(nextPath)
}

let error = ""

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData()
  const password = String(form.get("password") ?? "")

  if (verifyMasterPassword(password)) {
    const hash = getMasterPasswordHash()
    if (hash) {
      Astro.cookies.set(
        MASTER_AUTH_COOKIE,
        hash,
        getMasterAuthCookieOptions(Astro.url),
      )
    }
    return Astro.redirect(
      sanitizeNextPath(
        typeof form.get("next") === "string"
          ? (form.get("next") as string)
          : nextPath,
      ),
    )
  }

  error = "Invalid master password"
}
---

<Layout>
  <main class="min-h-svh flex items-center justify-center p-6 bg-background">
    <div class="w-full max-w-sm rounded-xl border bg-card p-6 shadow-sm">
      <h1 class="text-xl font-semibold">Nexus Lock</h1>
      <p class="mt-1 text-sm text-muted-foreground">
        Enter the master password to continue.
      </p>

      <form method="post" class="mt-5 space-y-4">
        <input type="hidden" name="next" value={nextPath} />
        <div class="space-y-1.5">
          <label for="password" class="text-sm font-medium">Master password</label>
          <input
            id="password"
            name="password"
            type="password"
            required
            autofocus
            class="h-10 w-full rounded-md border bg-background px-3 text-sm outline-none ring-0 focus-visible:ring-2 focus-visible:ring-ring"
          />
        </div>

        {error && <p class="text-sm text-destructive">{error}</p>}

        <button
          type="submit"
          class="inline-flex h-10 w-full items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:opacity-95"
        >
          Unlock
        </button>
      </form>
    </div>
  </main>
</Layout>
